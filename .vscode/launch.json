{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch RelativeFormulas",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/RelativeFormulas.Presentation/bin/Debug/net8.0/RelativeFormulas.Presentation.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/RelativeFormulas.Presentation",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Local"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}