@model RelativeFormulas.Domain.Entities.Recipe
@{
    ViewData["Title"] = Model.Title;
}

<article>
    <header>
        <h1>@Model.Title</h1>
        <small>Added @Model.CreatedAt.ToString("MMMM d, yyyy")</small>
        @await Html.PartialAsync("~/Views/Shared/_TagList.cshtml", Model.RecipeTags)
    </header>

    @await Html.PartialAsync("_FavoriteButton", (FavoriteButtonViewModel)ViewBag.FavoriteButton)

    @if (Model.Images.Any())
    {
        <div class="recipe-image-gallery">
            @foreach (var image in Model.Images.OrderBy(i => i.SortOrder))
            {
                <figure>
                    <img src="@image.FilePath" alt="Recipe card for @Model.Title" />
                    @if (!string.IsNullOrEmpty(image.Caption))
                    {
                        <figcaption>@image.Caption</figcaption>
                    }
                </figure>
            }
        </div>
    }

    @if (Model.RecipeIngredients.Any())
    {
        <section>
            <h2>Ingredients</h2>
            <ul>
                @foreach (var ri in Model.RecipeIngredients)
                {
                    <li>
                        @ri.Quantity
                        @if (!string.IsNullOrEmpty(ri.Unit))
                        {
                            <span>@ri.Unit</span>
                        }
                        @ri.Ingredient.Name
                    </li>
                }
            </ul>
        </section>
    }

    <section>
        <h2>Transcription</h2>
        <blockquote>@Model.TranscriptionText</blockquote>
    </section>

    <section>
        <h2>Instructions</h2>
        <p>@Model.InstructionsText</p>
    </section>
</article>

<a asp-action="Index">&larr; Back to all recipes</a>
<a href="/recipes/@Model.Slug/print"
   class="no-print"
   style="margin-left:1rem;"
   onclick="window.open(this.href,'_blank','width=900,height=700'); return false;">Print</a>
