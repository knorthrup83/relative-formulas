@{
    ViewData["Title"] = "Register";
}

<article style="max-width: 480px; margin: 2rem auto;">
    <header><h1>Create an account</h1></header>

    @if (ViewBag.Error is not null)
    {
        <p style="color: var(--pico-del-color);">@ViewBag.Error</p>
    }

    <form method="post" action="/register">
        @Html.AntiForgeryToken()

        <label for="displayName">Display Name</label>
        <input type="text" id="displayName" name="displayName" required autocomplete="name" />

        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" />

        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="new-password" />

        <button type="submit">Register</button>
    </form>

    <p>Already have an account? <a href="/login">Log in</a></p>
</article>
